{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://placeholder-replace-with-railway-url.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
