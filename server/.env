# ─── DevOps Portfolio — Express Server Config v2.0 ──────────────────────────

# ── Resend Email API (kept as backup) ────────────────────────────────────────
RESEND_API_KEY=re_bLot3qUe_Rq8xr14gQQcWXQUew3UD2EQA

# ── Gmail SMTP (primary — sends to anyone, no restrictions) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=farhanharoon2020@gmail.com
SMTP_PASS=dtitvhpmjxqfilqq

# ── Who receives contact form submissions ───────────────────────────────────
RECEIVER_EMAIL=farhanharoon2020@gmail.com

# ── Server Port ─────────────────────────────────────────────────────────────
PORT=5000

# ── Frontend URL (for CORS in production) ───────────────────────────────────
# Leave blank for local dev, set to your deployed URL in production
FRONTEND_URL=

# ── GitHub Personal Access Token ────────────────────────────────────────────
# Increases API rate limit from 60 to 5000 req/hr
# Create at: https://github.com/settings/tokens (classic, no scopes needed for public data)
GITHUB_TOKEN=

# ── Admin Key ───────────────────────────────────────────────────────────────
# Set a long random secret to protect /api/admin/* endpoints
# Usage: add header  X-Admin-Key: <your-key>  to requests
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-me-to-a-long-random-secret

# ── Resume PDF Path ─────────────────────────────────────────────────────────
# Absolute or relative path to your resume PDF
# Default: client/public/resume.pdf  (place file there and leave this blank)
RESUME_PATH=

# ── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development
