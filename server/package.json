    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "marked": "^15.0.12",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "resend": "^6.12.4",
