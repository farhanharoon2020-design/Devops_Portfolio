# ─── DevOps Portfolio — Express Server Config v2.0 (EXAMPLE) ───────────────
# Copy this to .env and fill in your values. Never commit .env to git!

# ── Gmail SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# ── Who receives contact form submissions ───────────────────────────────────
RECEIVER_EMAIL=your@gmail.com

# ── Server Port ─────────────────────────────────────────────────────────────
PORT=5000

# ── Frontend URL (for CORS in production) ───────────────────────────────────
FRONTEND_URL=

# ── GitHub Personal Access Token ────────────────────────────────────────────
# Optional — increases rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# ── Admin Key ───────────────────────────────────────────────────────────────
# Protect /api/admin/* endpoints with a secret key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=

# ── Resume PDF Path ─────────────────────────────────────────────────────────
# Default: client/public/resume.pdf  (leave blank to use default)
RESUME_PATH=

# ── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development
